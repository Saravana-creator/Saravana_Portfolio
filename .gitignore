# ══════════════════════════════════════════════════════════════════════════════
# .gitignore — Saravana Perumal M · Portfolio (Frontend-only · Vite + React)
# ══════════════════════════════════════════════════════════════════════════════


# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz


# ── Build & Output ────────────────────────────────────────────────────────────
dist/
dist-ssr/
build/
out/


# ── Vite / TypeScript ─────────────────────────────────────────────────────────
.vite/
*.tsbuildinfo
tsconfig.tsbuildinfo


# ── Environment & Secrets ─────────────────────────────────────────────────────
# ⚠️  Never commit .env files — use .env.example as a safe template
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local


# ── OS Artifacts ──────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~


# ── Editor & IDE ──────────────────────────────────────────────────────────────
# VS Code — allow shared recommended settings; ignore personal/generated ones
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# JetBrains (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*.swn
*.kate-swp
Session.vim

# Emacs
\#*\#
.#*


# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# ── Testing & Coverage ────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/
test-results/
playwright-report/
blob-report/
playwright/.cache/


# ── Package Manager Caches ────────────────────────────────────────────────────
.npm/
.eslintcache
.stylelintcache
.parcel-cache/
.cache/
.temp/
.tmp/


# ── Vercel / Deployment ───────────────────────────────────────────────────────
.vercel/
.netlify/


# ── Misc ──────────────────────────────────────────────────────────────────────
*.local
*.orig
*.bak
*.rej
