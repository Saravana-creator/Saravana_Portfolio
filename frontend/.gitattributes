# Auto-detect text files and normalise line endings to LF in the repo
# (Windows users get CRLF on checkout, everyone else gets LF)
* text=auto eol=lf

# Explicitly declare text files
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.svg   text eol=lf
*.env*  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf

# Binary files — no text processing
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.pdf   binary
*.zip   binary
